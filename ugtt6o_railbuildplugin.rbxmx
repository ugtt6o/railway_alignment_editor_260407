		<Item class="ModuleScript" referent="RBX814E0340F8F040B4B6DCDBFF7FB22E1F">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local module = {}

--[[
  RAILBUILDER_GENERATE
  -----------------------------------------------------------------------
  引数:
    POINTS_FOLDERS      []Folder   CP_XXXX を含むフォルダのテーブル
                                   （単体の場合も {folder} で包んで渡す）
    OUTPUT_FOLDER       Folder     出力先（nil → workspace）
    STUDS_PER_METER     number
    PHISICAL_GAUGE      number|nil  nil または 0 → 物理レール無効
    PHISICALRAIL_DETAIL table|nil   require 済みテーブル
    RAIL_MODEL          Model|nil
    STRUCTURE_MODEL     []Model
    STRUCTURE_CANT_N    number
    STRUCTURE_HANI      {min,max}|nil
    STRUCTURE_HANTEN    bool

  出力フォルダ構造:
    OUTPUT_FOLDER/
      {入力フォルダ名}/
        Rails/        ← 物理レール（Part）+ RAIL_MODEL（Model）
        Structures/   ← STRUCTURE_MODEL（Model）
--]]

function module.RAILBUILDER_GENERATE(
	POINTS_FOLDERS,
	OUTPUT_FOLDER,
	STUDS_PER_METER,
	PHISICAL_GAUGE,
	PHISICALRAIL_DETAIL,
	RAIL_MODEL,
	STRUCTURE_MODEL,
	STRUCTURE_CANT_N,
	STRUCTURE_HANI,
	STRUCTURE_HANTEN
)

	-- -------------------------------------------------------
	-- PHISICALRAIL_DETAIL バリデーション & デフォルト補完
	-- -------------------------------------------------------
	local function validateRailDetail(d)
		if d == nil then
			d = {}
		elseif type(d) ~= "table" then
			return false, "PHISICALRAIL_DETAIL は table である必要があります（得られた型: " .. type(d) .. "）"
		end

		if d.CanCollide    == nil then d.CanCollide    = true                    end
		if d.Width         == nil then d.Width         = 1                       end
		if d.Height        == nil then d.Height        = 1                       end
		if d.Transparency  == nil then d.Transparency  = 1                       end
		if d.Material      == nil then d.Material      = Enum.Material.Metal     end
		if d.TopSurface    == nil then d.TopSurface    = Enum.SurfaceType.Smooth end
		if d.BottomSurface == nil then d.BottomSurface = Enum.SurfaceType.Smooth end

		if type(d.CanCollide) ~= "boolean" then
			return false, "PHISICALRAIL_DETAIL.CanCollide は boolean である必要があります"
		end
		if type(d.Width) ~= "number" or d.Width <= 0 then
			return false, "PHISICALRAIL_DETAIL.Width は正の number である必要があります"
		end
		if type(d.Height) ~= "number" or d.Height <= 0 then
			return false, "PHISICALRAIL_DETAIL.Height は正の number である必要があります"
		end
		if type(d.Transparency) ~= "number" or d.Transparency < 0 or d.Transparency > 1 then
			return false, "PHISICALRAIL_DETAIL.Transparency は 0〜1 の number である必要があります"
		end

		return true, d
	end

	local ok, result = validateRailDetail(PHISICALRAIL_DETAIL)
	if not ok then
		return false, "[RAILBUILDER] PHISICALRAIL_DETAIL エラー: " .. result
	end
	local RD = result

	-- -------------------------------------------------------
	-- 引数デフォルト
	-- -------------------------------------------------------
	STUDS_PER_METER = STUDS_PER_METER or 3.571428

	local phisicrail = (PHISICAL_GAUGE ~= nil and PHISICAL_GAUGE > 0)
	local GAUGE      = PHISICAL_GAUGE or 9
	local HALF_GAUGE = GAUGE / 2

	local CANT_OFFSET = STRUCTURE_CANT_N or -6
	local HANTEN_CF   = STRUCTURE_HANTEN and CFrame.Angles(0, math.pi, 0) or CFrame.identity

	local HANI_MIN = STRUCTURE_HANI and STRUCTURE_HANI[1] or nil
	local HANI_MAX = STRUCTURE_HANI and STRUCTURE_HANI[2] or nil

	local ROOT = OUTPUT_FOLDER or workspace

	-- -------------------------------------------------------
	-- POINTS_FOLDERS の正規化
	-- Folder が単体で渡された場合もテーブルに統一する
	-- -------------------------------------------------------
	local folderList
	if typeof(POINTS_FOLDERS) == "Instance" and POINTS_FOLDERS:IsA("Folder") then
		folderList = { POINTS_FOLDERS }
		warn("[RAILBUILDER] POINTS_FOLDERS にテーブルではなく単体 Folder が渡されました。自動的に変換します。")
	elseif type(POINTS_FOLDERS) == "table" then
		folderList = POINTS_FOLDERS
	else
		warn("[RAILBUILDER] POINTS_FOLDERS が不正です。処理を中止します。")
		return false
	end

	if #folderList == 0 then
		warn("[RAILBUILDER] POINTS_FOLDERS が空です。処理を中止します。")
		return false
	end

	-- workspace 内モデルの警告（テンプレートは ServerStorage 推奨）
	if RAIL_MODEL and RAIL_MODEL:IsDescendantOf(workspace) then
		warn("[RAILBUILDER] RAIL_MODEL が workspace 内にあります。ServerStorage か ReplicatedStorage を推奨します。")
	end
	if STRUCTURE_MODEL then
		for _, m in ipairs(STRUCTURE_MODEL) do
			if m:IsDescendantOf(workspace) then
				warn("[RAILBUILDER] STRUCTURE_MODEL '" .. m.Name .. "' が workspace 内にあります。")
			end
		end
	end

	-- -------------------------------------------------------
	-- 共通ユーティリティ：セグメント中央の CFrame を返す
	--
	-- 両端の UpVector を補間してカントを保持した up を作り、
	-- グラム・シュミット法で forward と直交させてから
	-- CFrame.lookAt に渡す。
	-- lookAt は up が事前に直交化されていれば丸めずにそのまま使う。
	--
	-- 戻り値の LookVector は -Z（= -forward）なので、
	-- 取り出す際は必ず -segCF.LookVector で反転すること。
	-- -------------------------------------------------------
	local function buildSegmentCF(cf0, cf1)
		local pos0    = cf0.Position
		local pos1    = cf1.Position
		local segment = pos1 - pos0
		local length  = segment.Magnitude
		if length < 0.001 then return nil, 0 end

		local forward = segment.Unit

		local up_hint = cf0.UpVector + cf1.UpVector
		if up_hint.Magnitude < 0.001 then
			up_hint = Vector3.yAxis
		else
			up_hint = up_hint.Unit
		end

		local right = forward:Cross(up_hint)
		if right.Magnitude < 0.001 then
			right = Vector3.xAxis
		else
			right = right.Unit
		end
		local up = right:Cross(forward).Unit

		local mid = (pos0 + pos1) / 2
		return CFrame.lookAt(mid, mid + forward, up), length
	end

	-- -------------------------------------------------------
	-- 1フォルダ分の処理
	-- railFolder / structFolder を受け取って中に書き込む
	-- -------------------------------------------------------
	local function processFolder(parts, railFolder, structFolder)

		-- 物理レール生成（左右1対）
		local function createRailPair(cf0, cf1)
			local segCF, length = buildSegmentCF(cf0, cf1)
			if not segCF then return end

			local right   = segCF.RightVector
			local up      = segCF.UpVector
			local forward = -segCF.LookVector
			local mid     = segCF.Position

			local function createSide(sign)
				local sideMid = mid + right * (HALF_GAUGE * sign)
				local railCF  = CFrame.lookAt(sideMid, sideMid + forward, up)

				local part         = Instance.new("Part")
				part.Anchored      = true
				part.CanCollide    = RD.CanCollide
				part.Material      = RD.Material
				part.Size          = Vector3.new(RD.Width, RD.Height, length)
				part.CFrame        = railCF
				part.TopSurface    = RD.TopSurface
				part.BottomSurface = RD.BottomSurface
				part.Transparency  = RD.Transparency
				part.Parent        = railFolder
			end

			createSide(-1)
			createSide( 1)
		end

		-- RAIL_MODEL 配置
		local function placeRailModel(cf0, cf1)
			local segCF, _ = buildSegmentCF(cf0, cf1)
			if not segCF then return end

			local clone = RAIL_MODEL:Clone()
			clone.Parent = railFolder
			clone:PivotTo(segCF)
		end

		-- STRUCTURE_MODEL 配置
		local function placeStructureModels(cf0, cf1)
			local segCF, _ = buildSegmentCF(cf0, cf1)
			if not segCF then return end

			local _rx, _ry, rz = segCF:ToOrientation()
			local mid     = segCF.Position
			local forward = -segCF.LookVector
			local cfFlat  = CFrame.lookAt(mid, mid + forward, Vector3.yAxis)

			local finalCF = cfFlat + cfFlat.RightVector * (rz * CANT_OFFSET)
			finalCF       = finalCF * HANTEN_CF

			for _, template in ipairs(STRUCTURE_MODEL) do
				local clone = template:Clone()
				clone.Parent = structFolder
				clone:PivotTo(finalCF)
			end
		end

		-- メインループ
		for i = 1, #parts - 1 do
			local cf0    = parts[i].CFrame
			local cf1    = parts[i + 1].CFrame
			local cpNum0 = tonumber(string.match(parts[i].Name,     "%d+")) or 0
			local cpNum1 = tonumber(string.match(parts[i + 1].Name, "%d+")) or 0

			if phisicrail then
				createRailPair(cf0, cf1)
			end

			if RAIL_MODEL then
				placeRailModel(cf0, cf1)
			end

			local inHani = true
			if HANI_MIN and cpNum0 < HANI_MIN then inHani = false end
			if HANI_MAX and cpNum1 > HANI_MAX then inHani = false end

			if inHani and STRUCTURE_MODEL and #STRUCTURE_MODEL > 0 then
				placeStructureModels(cf0, cf1)
			end
		end
	end

	-- -------------------------------------------------------
	-- 全フォルダをループ処理
	-- -------------------------------------------------------
	for _, pointsFolder in ipairs(folderList) do

		-- BasePart のみ抽出・CP番号順ソート
		local parts = {}
		for _, child in ipairs(pointsFolder:GetChildren()) do
			if child:IsA("BasePart") then
				table.insert(parts, child)
			end
		end

		table.sort(parts, function(a, b)
			local na = tonumber(string.match(a.Name, "%d+")) or 0
			local nb = tonumber(string.match(b.Name, "%d+")) or 0
			return na < nb
		end)

		print(string.format("[RAILBUILDER] '%s': CP数 = %d", pointsFolder.Name, #parts))

		if #parts < 2 then
			warn(string.format("[RAILBUILDER] '%s': CP が 2 つ未満のためスキップします", pointsFolder.Name))
		else
			-- 出力フォルダを入力フォルダ名で作成
			--   ROOT/
			--     {pointsFolder.Name}/
			--       Rails/
			--       Structures/
			local trackRoot = Instance.new("Folder")
			trackRoot.Name  = pointsFolder.Name
			trackRoot.Parent = ROOT

			local railFolder = Instance.new("Folder")
			railFolder.Name  = "Rails"
			railFolder.Parent = trackRoot

			local structFolder = Instance.new("Folder")
			structFolder.Name  = "Structures"
			structFolder.Parent = trackRoot

			processFolder(parts, railFolder, structFolder)
		end
	end

	return true
end

return module]]></ProtectedString>
