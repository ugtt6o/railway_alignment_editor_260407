------------------------------------------------------------------------
-- [2] タブ切り替え
------------------------------------------------------------------------

local TABS = {
	{ button = frame._00_sentaku._01_Nodes,  frame = nodesframe  },
	{ button = frame._00_sentaku._02_Rails,  frame = railsframe  },
	{ button = frame._00_sentaku._03_Struct, frame = structframe },
}

local function switchTab(targetFrame)
	for _, tab in ipairs(TABS) do
		tab.frame.Visible = (tab.frame == targetFrame)
	end
end

switchTab(TABS[1].frame)

for _, tab in ipairs(TABS) do
	local f = tab.frame
	tab.button.MouseButton1Click:Connect(function()
		switchTab(f)
	end)
end

------------------------------------------------------------------------
-- [3] ログシステム
------------------------------------------------------------------------

local MAX_LOG_LINES = 22
local logLines      = {}

local LogColor = {
	INFO    = "#000000",
	SUCCESS = "#008000",
	WARN    = "#fd7e00",
	ERROR   = "#ff0000",
}

local function log(color, message)
	table.insert(logLines, string.format('<font color="%s">%s</font>', color, message))

	if #logLines > MAX_LOG_LINES then
		table.remove(logLines, 1)
	end

	local text = table.concat(logLines, "\n")
	nodesframe.Logs.Logging.Text  = text
	railsframe.Logs.Logging.Text  = text
	structframe.Logs.Logging.Text = text
end

------------------------------------------------------------------------
-- [4] 共通ユーティリティ
------------------------------------------------------------------------

local Selection = game:GetService("Selection")

local function parseNumber(text, fallback, label)
	local n = tonumber(text)
	if n ~= nil then return n end
	-- 空文字はデフォルト値を使用（通知なし）
	if text == nil or text == "" then return fallback end
	-- 数値以外の文字列が入力された場合は警告
	if label then
		log(LogColor.WARN, string.format("「%s」に不正な値（%s）が入力されています。既定値 %s を使用します。", label, text, tostring(fallback)))
	end
	return fallback
end

local function parseOffsets(text)
	text = string.gsub(text, "%s", "")

	if text == "" then
		log(LogColor.INFO, "オフセット未設定 → 0 を使用します")
		return { 0 }
	end

	local offsets = {}
	for value in string.gmatch(text, "[^,]+") do
		local n = tonumber(value)
		if not n then
			log(LogColor.ERROR, "オフセットに不正な値があります: " .. value)
			return nil
		end
		table.insert(offsets, n)
	end

	log(LogColor.INFO, "オフセット設定: " .. text)
	return offsets
end

local function parseHani(text)
	text = string.gsub(text, "%s", "")

	if text == "" then return nil end

	local parts = {}
	for v in string.gmatch(text, "[^,]+") do
		table.insert(parts, tonumber(v))
	end

	if #parts ~= 2 or not parts[1] or not parts[2] then
		log(LogColor.ERROR, "範囲の形式が不正です（例: 1,100）: " .. text)
		return nil
	end

	log(LogColor.INFO, "範囲: CP" .. parts[1] .. " 〜 CP" .. parts[2])
	return { parts[1], parts[2] }
end

local function setLabelValue(label, value)
	if value then
		label.Text       = value.Name
		label.TextColor3 = Color3.fromRGB(0, 0, 0)
	else
		label.Text       = "未設定"
		label.TextColor3 = Color3.fromRGB(180, 0, 0)
	end
end

local function makeToggle(btn, lab, init)
	local state = init
	lab.Text       = tostring(state)
	lab.TextColor3 = state and Color3.fromRGB(0, 140, 0) or Color3.fromRGB(80, 80, 80)

	btn.MouseButton1Click:Connect(function()
		state          = not state
		lab.Text       = tostring(state)
		lab.TextColor3 = state and Color3.fromRGB(0, 140, 0) or Color3.fromRGB(80, 80, 80)
	end)

	return function() return state end
end

------------------------------------------------------------------------
-- 選択待ちシステム
--
-- 単一選択: ボタン押下（何度押しても初期化してやり直し）
--           → SelectionChanged で選択を検出 → 型チェック
--           → OK: Value 書き込み・待ち終了
--           → NG: ログを出して待ち終了
--           CancelButton: 待ち終了のみ
--
-- 複数選択: ボタン押下（何度押しても初期化してやり直し）
--           → SelectionChanged で選択を検出 → 型チェック
--           → OK: dir に追加・待ち継続
--           → NG: ログを出して待ち継続
--           CancelButton: 待ち終了のみ（追加済みはそのまま）
--
-- 待ち状態の視覚フィードバック:
--   ・ボタンの親フレームをオレンジ色に変更
--   ・CancelButton を表示
--   ・単一: ラベルを "← 選択してください" に変更
--   ・複数: ラベルを "選択物を追加" に変更
------------------------------------------------------------------------

local COLOR_WAITING = Color3.fromRGB(255, 165,   0)  -- 待ち中：オレンジ
local COLOR_DEFAULT = Color3.fromRGB(255, 255, 255)  -- フレーム通常色

local waitingFor = nil  -- 現在の待ち状態テーブル（nil = 待ちなし）

--- 待ち状態を解除して視覚状態を初期化する
local function cancelWaiting()
	if not waitingFor then return end
	waitingFor.frame.BackgroundColor3 = COLOR_DEFAULT
	waitingFor.cancelBtn.Visible      = false
	waitingFor = nil
end

--- 待ち状態を開始する
--- 既に待ち中でも無条件にリセットして再スタートする
local function startWaiting(config)
	cancelWaiting()  -- 既存の待ちがあればリセット（多重起動防止・再起動対応）

	waitingFor = config
	config.frame.BackgroundColor3 = COLOR_WAITING
	config.cancelBtn.Visible      = true

	-- ラベルは現在の状態を表示するのみ（待ち中でも変更しない）

	log(LogColor.WARN, config.guideMessage)
end

-- SelectionChanged を監視して待ち状態を処理する
Selection.SelectionChanged:Connect(function()
	if not waitingFor then return end

	local selected = Selection:Get()
	if #selected == 0 then return end

	local obj = selected[1]

	-- 型チェック
	if not waitingFor.validator(obj) then
		log(LogColor.ERROR, string.format(
			"%s は対象外です（%s）。%s を選択してください。",
			tostring(obj.Name),
			tostring(obj.ClassName),
			tostring(waitingFor.expectedType or "正しい種類")
			))
		-- 単一は待ち終了、複数は継続
		if not waitingFor.isMulti then
			cancelWaiting()
		end
		Selection:Set({})
		return
	end

	if waitingFor.isMulti then
		-- 複数選択：追加して待ち継続
		local ov  = Instance.new("ObjectValue")
		ov.Name   = string.format("%s_%04d", waitingFor.namePrefix, #waitingFor.dir:GetChildren() + 1)
		ov.Value  = obj
		ov.Parent = waitingFor.dir
		waitingFor.onAdd()
		Selection:Set({})
	else
		-- 単一選択：待ち解除してから Value 書き込み
		-- （先に nil にすることで Value 代入による SelectionChanged 再トリガーを無視）
		local ov        = waitingFor.ov
		local onConfirm = waitingFor.onConfirm
		local frame     = waitingFor.frame
		local cancelBtn = waitingFor.cancelBtn
		cancelWaiting()
		frame.BackgroundColor3 = COLOR_DEFAULT
		cancelBtn.Visible      = false
		ov.Value = obj
		onConfirm(obj)
		Selection:Set({})
	end
end)

--- 単一選択ボタン用ヘルパー
local function bindSelectButton(btn, ov, label, frame, cancelBtn, validator, expectedType, guide, onConfirm)
	btn.MouseButton1Click:Connect(function()
		startWaiting({
			label        = label,
			frame        = frame,
			cancelBtn    = cancelBtn,
			ov           = ov,
			validator    = validator,
			expectedType = expectedType,
			guideMessage = guide,
			isMulti      = false,
			onConfirm    = onConfirm or function(o) setLabelValue(label, o) end,
		})
	end)
	cancelBtn.MouseButton1Click:Connect(function()
		cancelWaiting()
		setLabelValue(label, ov.Value)
	end)
end

--- 複数選択ボタン用ヘルパー
local function bindMultiSelectButton(btn, dir, label, frame, cancelBtn, namePrefix, validator, expectedType, guide, onAdd)
	btn.MouseButton1Click:Connect(function()
		startWaiting({
			label        = label,
			frame        = frame,
			cancelBtn    = cancelBtn,
			dir          = dir,
			namePrefix   = namePrefix,
			validator    = validator,
			expectedType = expectedType,
			guideMessage = guide,
			isMulti      = true,
			onAdd        = onAdd,
		})
	end)
	cancelBtn.MouseButton1Click:Connect(function()
		cancelWaiting()
		onAdd()  -- ラベルを現在の件数で更新
	end)
end

------------------------------------------------------------------------
-- [5] 設定フォルダ管理 (ReplicatedStorage.RAILBUILDER_CONFIG)
------------------------------------------------------------------------

local CONFIG_FOLDER_NAME = "RAILBUILDER_CONFIG"

local function ensureConfigFolder()
	local rs     = game.ReplicatedStorage
	local folder = rs:FindFirstChild(CONFIG_FOLDER_NAME)

	if not folder then
		folder        = Instance.new("Folder")
		folder.Name   = CONFIG_FOLDER_NAME
		folder.Parent = rs
	end

	local AS_VALUES = { "Module_kokodayo", "start_kokodayo", "output_kokodayo" }
	local RB_VALUES = { "rb_outputFolder", "rb_railDetail", "rb_railModel" }
	local SP_VALUES = { "sp_outputFolder", "sp_placeModel" }

	for _, name in ipairs(AS_VALUES) do
		if not folder:FindFirstChild(name) then
			local ov = Instance.new("ObjectValue")
			ov.Name = name; ov.Parent = folder
		end
	end
	for _, name in ipairs(RB_VALUES) do
		if not folder:FindFirstChild(name) then
			local ov = Instance.new("ObjectValue")
			ov.Name = name; ov.Parent = folder
		end
	end
	for _, name in ipairs(SP_VALUES) do
		if not folder:FindFirstChild(name) then
			local ov = Instance.new("ObjectValue")
			ov.Name = name; ov.Parent = folder
		end
	end

	for _, name in ipairs({ "rb_pointsFolders", "rb_structModels", "sp_pointsFolders", "sp_bTargetNodes" }) do
		if not folder:FindFirstChild(name) then
			local f = Instance.new("Folder")
			f.Name = name; f.Parent = folder
		end
	end

	return folder
end

local cfgFolder      = ensureConfigFolder()

local modulewhere    = cfgFolder:FindFirstChild("Module_kokodayo")
local startwhere     = cfgFolder:FindFirstChild("start_kokodayo")
local outputwhere    = cfgFolder:FindFirstChild("output_kokodayo")

local rb_pointsDir   = cfgFolder:FindFirstChild("rb_pointsFolders")
local rb_outputOV    = cfgFolder:FindFirstChild("rb_outputFolder")
local rb_detailOV    = cfgFolder:FindFirstChild("rb_railDetail")
local rb_railModelOV = cfgFolder:FindFirstChild("rb_railModel")
local rb_structDir   = cfgFolder:FindFirstChild("rb_structModels")

local sp_pointsDir   = cfgFolder:FindFirstChild("sp_pointsFolders")
local sp_outputOV    = cfgFolder:FindFirstChild("sp_outputFolder")
local sp_modelOV     = cfgFolder:FindFirstChild("sp_placeModel")
local sp_bTargetDir  = cfgFolder:FindFirstChild("sp_bTargetNodes")

modulewhere.Value    = nil
startwhere.Value     = nil
outputwhere.Value    = nil
rb_outputOV.Value    = nil
rb_detailOV.Value    = nil
rb_railModelOV.Value = nil
sp_outputOV.Value    = nil
sp_modelOV.Value     = nil

-- 起動時に複数選択フォルダ・ストラクチャをクリア
rb_pointsDir:ClearAllChildren()
rb_structDir:ClearAllChildren()
sp_pointsDir:ClearAllChildren()
sp_bTargetDir:ClearAllChildren()

------------------------------------------------------------------------
-- [6] AlignmentSolver (_01_Nodes タブ)
------------------------------------------------------------------------

local generator = require(script.AlignmentSolver)

local AS_Module          = nil
local AS_StartAttachment = nil
local AS_OutputFolder    = nil

local AS_DEFAULT = {
	studsPerMeter = 3.571428,
	gauge         = 1.067,
	cant          = 0.105,
	nodeInterval  = 2.0,
}

bindSelectButton(
	nodesframe.Set.Frame.one.Frame.TextButton,
	modulewhere,
	nodesframe.Set.Frame.one.Frame.TextLabel,
	nodesframe.Set.Frame.one.Frame,
	nodesframe.Set.Frame.one.CancelButton,
	function(obj) return obj:IsA("ModuleScript") end,
	"ModuleScript",
	"[AS] 線形 ModuleScript を選択してください",
	function(obj)
		AS_Module = obj
		setLabelValue(nodesframe.Set.Frame.one.Frame.TextLabel, obj)
		log(LogColor.INFO, "[AS] Module を設定しました：" .. obj.Name)
		local ok, data = pcall(function()
			local clone = obj:Clone(); clone.Parent = obj.Parent
			local r = require(clone); clone:Destroy(); return r
		end)
		if ok and data and data.alignment and data.alignment.elements then
			log(LogColor.INFO, "[AS] elements 数: " .. #data.alignment.elements)
		elseif not ok then
			log(LogColor.ERROR, "[AS] Module の読み込みに失敗: " .. tostring(data))
		else
			log(LogColor.ERROR, "[AS] Module 構造が不正です")
		end
	end
)

bindSelectButton(
	nodesframe.Set.Frame.two.Frame.TextButton,
	startwhere,
	nodesframe.Set.Frame.two.Frame.TextLabel,
	nodesframe.Set.Frame.two.Frame,
	nodesframe.Set.Frame.two.CancelButton,
	function(obj) return obj:IsA("BasePart") or obj:IsA("Attachment") end,
	"Part または Attachment",
	"[AS] 開始点 Part または Attachment を選択してください",
	function(obj)
		AS_StartAttachment = obj
		setLabelValue(nodesframe.Set.Frame.two.Frame.TextLabel, obj)
		log(LogColor.INFO, "[AS] START_ATTACHMENT を設定しました：" .. obj.Name)
	end
)

bindSelectButton(
	nodesframe.Set.Frame.three.Frame.TextButton,
	outputwhere,
	nodesframe.Set.Frame.three.Frame.TextLabel,
	nodesframe.Set.Frame.three.Frame,
	nodesframe.Set.Frame.three.CancelButton,
	function(obj) return obj:IsA("Folder") end,
	"Folder",
	"[AS] 出力先 Folder を選択してください",
	function(obj)
		AS_OutputFolder = obj
		setLabelValue(nodesframe.Set.Frame.three.Frame.TextLabel, obj)
		log(LogColor.INFO, "[AS] OUTPUT_FOLDER を設定しました：" .. obj.Name)
	end
)

local function validateAS()
	if not AS_Module then
		log(LogColor.ERROR, "[AS] Module が選択されていません"); return false
	end
	if not AS_StartAttachment then
		log(LogColor.ERROR, "[AS] Startpoint が選択されていません"); return false
	end
	if not AS_StartAttachment:IsA("Attachment") then
		if not AS_StartAttachment:FindFirstChildWhichIsA("Attachment") then
			log(LogColor.ERROR, "[AS] Part の直下に Attachment を配置してください"); return false
		end
	end
	return true
end

local asCfg = nodesframe.Config.Frame

nodesframe.Run.MouseButton1Click:Connect(function()
	log(LogColor.SUCCESS, "[AS] 実行しました")
	if not validateAS() then return end

	local studsPerMeter = parseNumber(asCfg.a.Frame.TextBox.Text, AS_DEFAULT.studsPerMeter, "スタッド/m")
	local gauge         = parseNumber(asCfg.b.Frame.TextBox.Text, AS_DEFAULT.gauge, "軌間")
	local cant          = parseNumber(asCfg.c.Frame.TextBox.Text, AS_DEFAULT.cant, "カント")
	local nodeInterval  = parseNumber(asCfg.d.Frame.TextBox.Text, AS_DEFAULT.nodeInterval, "ノード間隔")
	local trackOffsets  = parseOffsets(asCfg.e.Frame.TextBox.Text)
	if not trackOffsets then return end

	if outputwhere.Value then AS_OutputFolder = outputwhere.Value end

	log(LogColor.INFO, "[AS] Module: "        .. tostring(AS_Module))
	log(LogColor.INFO, "[AS] Start: "         .. tostring(AS_StartAttachment))
	log(LogColor.INFO, "[AS] Output: "        .. tostring(AS_OutputFolder))
	log(LogColor.INFO, "[AS] studsPerMeter: " .. studsPerMeter)
	log(LogColor.INFO, "[AS] gauge: "         .. gauge)
	log(LogColor.INFO, "[AS] cant: "          .. cant)
	log(LogColor.INFO, "[AS] nodeInterval: "  .. nodeInterval)

	local ok, result = pcall(function()
		return generator.Generate(
			AS_Module, AS_StartAttachment, AS_OutputFolder,
			studsPerMeter, gauge, cant, nodeInterval, trackOffsets
		)
	end)

	if not ok then
		log(LogColor.ERROR, "[AS] エラー: " .. tostring(result)); return
	end
	if result then
		log(LogColor.SUCCESS, "[AS] 正常に完了しました")
	else
		log(LogColor.ERROR, "[AS] AlignmentSolver が false を返しました")
	end
end)

------------------------------------------------------------------------
-- [7] RailBuilder (_02_Rails タブ)
------------------------------------------------------------------------

local railBuilder = require(script.RailBuilder)

local RB = {
	pointsFolders = {},
	outputFolder  = nil,
	railDetail    = nil,
	railModel     = nil,
}

local RB_DEFAULT = {
	studsPerMeter = 3.571428,
	physicalGauge = 0,
	cantOffset    = -6,
}

local rbSet         = railsframe.Set.Frame
local rbCfgFrame    = railsframe.Config.Frame
local rbStructFrame = railsframe.Structures.Frame

local getHanten = makeToggle(
	rbStructFrame._04_.Frame.TextButton,
	rbStructFrame._04_.Frame.TextLabel,
	false
)

local function refreshRbPointsFolders()
	RB.pointsFolders = {}
	for _, ov in ipairs(rb_pointsDir:GetChildren()) do
		if ov:IsA("ObjectValue") and ov.Value then
			table.insert(RB.pointsFolders, ov.Value)
		end
	end
	local names = {}
	for _, f in ipairs(RB.pointsFolders) do table.insert(names, f.Name) end
	local display = #names > 0 and table.concat(names, ", ") or "未設定"
	rbSet._01_.Frame.TextLabel.Text       = display
	rbSet._01_.Frame.TextLabel.TextColor3 = #names > 0
		and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(180, 0, 0)
	log(LogColor.INFO, string.format("[RB] 線形フォルダ (%d件): %s", #RB.pointsFolders, display))
end

bindMultiSelectButton(
	rbSet._01_.Frame.TextButton,
	rb_pointsDir,
	rbSet._01_.Frame.TextLabel,
	rbSet._01_.Frame,
	rbSet._01_.CancelButton,
	"points",
	function(obj) return obj:IsA("Folder") end,
	"Folder",
	"[RB] 線形フォルダ（Folder）を選択してください",
	refreshRbPointsFolders
)

rbSet._01_.ClearButton.MouseButton1Click:Connect(function()
	local count = #rb_pointsDir:GetChildren()
	if count == 0 then log(LogColor.INFO, "[RB] クリアする線形フォルダがありません"); return end
	rb_pointsDir:ClearAllChildren()
	refreshRbPointsFolders()
	log(LogColor.WARN, string.format("[RB] 線形フォルダを %d 件クリアしました", count))
end)

local function collectStructModels()
	local models = {}
	for _, ov in ipairs(rb_structDir:GetChildren()) do
		if ov:IsA("ObjectValue") and ov.Value then table.insert(models, ov.Value) end
	end
	return models
end

local function refreshRbStructLabel()
	local count = #rb_structDir:GetChildren()
	local label = rbStructFrame._01_.Frame.TextLabel
	if count > 0 then
		label.Text       = string.format("%d 件設定済み", count)
		label.TextColor3 = Color3.fromRGB(0, 0, 0)
	else
		label.Text       = "未設定"
		label.TextColor3 = Color3.fromRGB(180, 0, 0)
	end
	log(LogColor.INFO, string.format("[RB] ストラクチャ: %d 件", count))
end

bindMultiSelectButton(
	rbStructFrame._01_.Frame.TextButton,
	rb_structDir,
	rbStructFrame._01_.Frame.TextLabel,
	rbStructFrame._01_.Frame,
	rbStructFrame._01_.CancelButton,
	"struct",
	function(obj) return obj:IsA("Model") end,
	"Model",
	"[RB] ストラクチャ Model を選択してください",
	refreshRbStructLabel
)

rbStructFrame._01_.ClearButton.MouseButton1Click:Connect(function()
	local count = #rb_structDir:GetChildren()
	if count == 0 then log(LogColor.INFO, "[RB] クリアするストラクチャがありません"); return end
	rb_structDir:ClearAllChildren()
	refreshRbStructLabel()
	log(LogColor.WARN, string.format("[RB] ストラクチャを %d 件クリアしました", count))
end)

bindSelectButton(
	rbSet._02_.Frame.TextButton,
	rb_outputOV,
	rbSet._02_.Frame.TextLabel,
	rbSet._02_.Frame,
	rbSet._02_.CancelButton,
	function(obj) return obj:IsA("Folder") end,
	"Folder",
	"[RB] 出力先 Folder を選択してください",
	function(obj)
		RB.outputFolder = obj
		setLabelValue(rbSet._02_.Frame.TextLabel, obj)
		log(LogColor.INFO, "[RB] 出力先: " .. obj.Name)
	end
)

bindSelectButton(
	rbCfgFrame._03_.Frame.TextButton,
	rb_detailOV,
	rbCfgFrame._03_.Frame.TextLabel,
	rbCfgFrame._03_.Frame,
	rbCfgFrame._03_.CancelButton,
	function(obj) return obj:IsA("ModuleScript") end,
	"ModuleScript",
	"[RB] 物理線路詳細 ModuleScript を選択してください",
	function(obj)
		RB.railDetail = obj
		setLabelValue(rbCfgFrame._03_.Frame.TextLabel, obj)
		log(LogColor.INFO, "[RB] 物理線路詳細: " .. obj.Name)
	end
)

bindSelectButton(
	rbCfgFrame._04_.Frame.TextButton,
	rb_railModelOV,
	rbCfgFrame._04_.Frame.TextLabel,
	rbCfgFrame._04_.Frame,
	rbCfgFrame._04_.CancelButton,
	function(obj) return obj:IsA("Model") end,
	"Model",
	"[RB] 線路ストラクチャ Model を選択してください",
	function(obj)
		RB.railModel = obj
		setLabelValue(rbCfgFrame._04_.Frame.TextLabel, obj)
		log(LogColor.INFO, "[RB] 線路ストラクチャ: " .. obj.Name)
	end
)

local function validateRB()
	if #RB.pointsFolders == 0 then
		log(LogColor.ERROR, "[RB] 線形フォルダが1つも設定されていません"); return false
	end
	return true
end

railsframe.Run.MouseButton1Click:Connect(function()
	log(LogColor.SUCCESS, "[RB] 実行しました")
	if not validateRB() then return end

	local studsPerMeter = parseNumber(rbCfgFrame._01_.Frame.TextBox.Text, RB_DEFAULT.studsPerMeter, "スタッド/m")
	local physGaugeRaw  = parseNumber(rbCfgFrame._02_.Frame.TextBox.Text, RB_DEFAULT.physicalGauge, "物理軌間")
	local cantOffset    = parseNumber(rbStructFrame._03_.Frame.TextBox.Text, RB_DEFAULT.cantOffset, "カント角オフセット")
	local physicalGauge = (physGaugeRaw and physGaugeRaw > 0) and physGaugeRaw or nil
	local hani          = parseHani(rbStructFrame._02_.Frame.TextBox.Text)
	local hanten        = getHanten()

	local railDetailData = nil
	if RB.railDetail then
		local ok, result = pcall(require, RB.railDetail)
		if not ok then
			log(LogColor.ERROR, "[RB] 物理線路詳細 Module の読み込みに失敗: " .. tostring(result)); return
		end
		railDetailData = result
	end

	local structModels = collectStructModels()

	local names = {}
	for _, f in ipairs(RB.pointsFolders) do table.insert(names, f.Name) end
	log(LogColor.INFO, string.format("[RB] 線形フォルダ (%d件): %s", #RB.pointsFolders, table.concat(names, ", ")))
	log(LogColor.INFO, "[RB] 出力先:            " .. tostring(RB.outputFolder  and RB.outputFolder.Name))
	log(LogColor.INFO, "[RB] studsPerMeter:     " .. studsPerMeter)
	log(LogColor.INFO, "[RB] 物理軌間:          " .. tostring(physicalGauge))
	log(LogColor.INFO, "[RB] カント角オフセット: " .. cantOffset)
	log(LogColor.INFO, "[RB] 範囲(HANI):        " .. (hani and (hani[1] .. "〜" .. hani[2]) or "全区間"))
	log(LogColor.INFO, "[RB] 反転(HANTEN):      " .. tostring(hanten))
	log(LogColor.INFO, "[RB] ストラクチャ数:     " .. #structModels)

	local ok, result = pcall(function()
		return railBuilder.RAILBUILDER_GENERATE(
			RB.pointsFolders, RB.outputFolder,
			studsPerMeter, physicalGauge, railDetailData,
			RB.railModel, structModels,
			cantOffset, hani, hanten
		)
	end)

	if not ok then log(LogColor.ERROR, "[RB] エラー: " .. tostring(result)); return end
	if result then log(LogColor.SUCCESS, "[RB] 正常に完了しました")
	else log(LogColor.ERROR, "[RB] RailBuilder が false を返しました") end
end)

------------------------------------------------------------------------
-- [8] StructPlacer (_03_Struct タブ)
--
-- STRUCTPLACER_GENERATE 引数マッピング:
--   POINTS_FOLDERS    ← sp_pointsDir 内 ObjectValues     ([]Folder)
--   OUTPUT_FOLDER     ← sp_outputOV.Value                (Folder / nil)
--   PLACE_MODEL       ← sp_modelOV.Value                 (Model)
--   CANT_OFFSET_LAT   ← spCfg._01_.Frame.TextBox         (number)
--   CANT_OFFSET_VERT  ← spCfg._02_.Frame.TextBox         (number)
--   ALIGN_TO_CANT     ← getSpCantTsuiju()                (bool)
--   STRUCTURE_HANTEN  ← getSpHanten()                    (bool)
--   STRUCTURE_HANI    ← spCfg._05_.Frame.TextBox         ({min,max} / nil)
--   MODE              ← spMode                           ("A" / "B")
--   SNAP_TO_CP        ← getSpSnapToCp()                  (bool)
-- [パターンA]
--   INTERVAL_BASE     ← spModeA._01_.Frame.TextBox       (number)
--   INTERVAL_UNIT     ← spUnitMode                       ("cp" / "meter")
--   INTERVAL_MIN      ← spModeA._02_.Frame.TextBox       (number / nil)
--   CURVATURE_SCALE   ← spModeA._03_.Frame.TextBox       (number)
--   STUDS_PER_METER   ← spModeA._04_.Frame.TextBox       (number) ※meterモード時
-- [パターンB]
--   TARGET_NODES      ← sp_bTargetDir 内 ObjectValues    ([]number)
------------------------------------------------------------------------

local structPlacer = require(script.StructPlacer)

local SP = {
	pointsFolders = {},
	outputFolder  = nil,
	placeModel    = nil,
}

local SP_DEFAULT = {
	cantOffsetLat  = 0,
	cantOffsetVert = 0,
	intervalBase   = { cp = 5, meter = 25 },
	curvatureScale = 0,
	studsPerMeter  = 3.571428,
}

local spSet   = structframe.Set.Frame
local spCfg   = structframe.Config.Frame
local spModeA = structframe.Mode.A
local spModeB = structframe.Mode.B

local getSpCantTsuiju = makeToggle(
	spCfg._03_.Frame.TextButton,
	spCfg._03_.Frame.TextLabel,
	false
)

local getSpHanten = makeToggle(
	spCfg._04_.Frame.TextButton,
	spCfg._04_.Frame.TextLabel,
	false
)

-- CP揃え(SNAP_TO_CP)トグル：true=CP位置に揃える / false=補完で正確な距離
local getSpSnapToCp = makeToggle(
	spCfg._06_.Frame.TextButton,
	spCfg._06_.Frame.TextLabel,
	false
)

-------- モード切り替え (A / B) --------

local spMode = "A"

local function switchSpMode(mode)
	spMode          = mode
	spModeA.Visible = (mode == "A")
	spModeB.Visible = (mode == "B")
	log(LogColor.INFO, "[SP] モード切り替え: パターン" .. mode)
end

switchSpMode("A")

local modea = true
structframe.Mode.TextButton.MouseButton1Click:Connect(function()
	modea = not modea
	switchSpMode(modea and "A" or "B")
end)

-------- 単位切り替え (CP / meter) --------

local spUnitMode    = "cp"
local spUnitBtn     = spModeA._01_.TextButton   -- 単位切り替えボタン（Frame外）
local spUnitTitle   = spModeA._01_.TextLabel    -- 単位ラベル（Frame外）
local spIntervalBox = spModeA._01_.Frame.TextBox -- 間隔値入力（CP/meter共通）

local function switchSpUnit(unit)
	spUnitMode       = unit
	spUnitTitle.Text = unit == "cp" and "間隔（CP）" or "間隔（m）"

	-- STUDS_PER_METER 入力欄はmeterモード時のみ表示
	spModeA._04_.Visible = (unit == "meter")

	-- PlaceholderText を単位に合わせて更新
	spIntervalBox.PlaceholderText = unit == "cp"
		and string.format("既定:%d (CP倍数)",  SP_DEFAULT.intervalBase.cp)
		or  string.format("既定:%d (メートル)", SP_DEFAULT.intervalBase.meter)

	log(LogColor.INFO, "[SP] 間隔単位: " .. unit)
end

switchSpUnit("cp")

spUnitBtn.MouseButton1Click:Connect(function()
	switchSpUnit(spUnitMode == "cp" and "meter" or "cp")
end)

-------- 線形フォルダ複数管理（SP用） --------

local function refreshSpPointsFolders()
	SP.pointsFolders = {}
	for _, ov in ipairs(sp_pointsDir:GetChildren()) do
		if ov:IsA("ObjectValue") and ov.Value then
			table.insert(SP.pointsFolders, ov.Value)
		end
	end
	local names = {}
	for _, f in ipairs(SP.pointsFolders) do table.insert(names, f.Name) end
	local display = #names > 0 and table.concat(names, ", ") or "未設定"
	spSet._01_.Frame.TextLabel.Text       = display
	spSet._01_.Frame.TextLabel.TextColor3 = #names > 0
		and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(180, 0, 0)
	log(LogColor.INFO, string.format("[SP] 線形フォルダ (%d件): %s", #SP.pointsFolders, display))
end

bindMultiSelectButton(
	spSet._01_.Frame.TextButton,
	sp_pointsDir,
	spSet._01_.Frame.TextLabel,
	spSet._01_.Frame,
	spSet._01_.CancelButton,
	"spPoints",
	function(obj) return obj:IsA("Folder") end,
	"Folder",
	"[SP] 線形フォルダ（Folder）を選択してください",
	refreshSpPointsFolders
)

spSet._01_.ClearButton.MouseButton1Click:Connect(function()
	local count = #sp_pointsDir:GetChildren()
	if count == 0 then log(LogColor.INFO, "[SP] クリアする線形フォルダがありません"); return end
	sp_pointsDir:ClearAllChildren()
	refreshSpPointsFolders()
	log(LogColor.WARN, string.format("[SP] 線形フォルダを %d 件クリアしました", count))
end)

-------- パターンB：対象ノード複数管理 --------

local function collectBTargetNodes()
	local nodes = {}
	for _, ov in ipairs(sp_bTargetDir:GetChildren()) do
		if ov:IsA("ObjectValue") then
			local n = tonumber(ov.Name:match("%d+"))
			if n then table.insert(nodes, n) end
		end
	end
	table.sort(nodes)
	return nodes
end

--- パターンB専用：sp_bTargetDir 内の ObjectValue.Value（BasePart）を直接収集
local function collectBTargetParts()
	local parts = {}
	for _, ov in ipairs(sp_bTargetDir:GetChildren()) do
		if ov:IsA("ObjectValue") and ov.Value and ov.Value:IsA("BasePart") then
			table.insert(parts, ov.Value)
		end
	end
	return parts
end

local function refreshBTargetLabel()
	local nodes = collectBTargetNodes()
	local strs  = {}
	for _, n in ipairs(nodes) do table.insert(strs, tostring(n)) end
	local display = #strs > 0 and table.concat(strs, ", ") or "未設定"
	spModeB._01_.Frame.TextLabel.Text       = display
	spModeB._01_.Frame.TextLabel.TextColor3 = #strs > 0
		and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(180, 0, 0)
	log(LogColor.INFO, string.format("[SP] 対象CP (%d件): %s", #nodes, display))
end

-- パターンB：CP追加は BasePart 選択 → CP番号を名前として ObjectValue に格納
-- bindMultiSelectButton の onAdd で番号を自前で処理するため、
-- validator 通過後に dir への書き込みを onAdd 内で行う特殊版
local spModeBAddBtn = spModeB._01_.Frame.TextButton
spModeBAddBtn.MouseButton1Click:Connect(function()
	startWaiting({
		label        = spModeB._01_.Frame.TextLabel,
		frame        = spModeB._01_.Frame,
		cancelBtn    = spModeB._01_.CancelButton,
		dir          = sp_bTargetDir,
		namePrefix   = "node",
		validator    = function(obj) return obj:IsA("BasePart") end,
		expectedType = "BasePart（CP）",
		guideMessage = "[SP] CP（BasePart）を選択してください",
		isMulti      = true,
		onAdd        = refreshBTargetLabel,
	})
end)

-- キャンセル：待ち終了のみ（追加済みはそのまま）
spModeB._01_.CancelButton.MouseButton1Click:Connect(function()
	cancelWaiting()
	refreshBTargetLabel()
end)

spModeB._01_.ClearButton.MouseButton1Click:Connect(function()
	local count = #sp_bTargetDir:GetChildren()
	if count == 0 then log(LogColor.INFO, "[SP] クリアする対象CPがありません"); return end
	sp_bTargetDir:ClearAllChildren()
	refreshBTargetLabel()
	log(LogColor.WARN, string.format("[SP] 対象CPを %d 件クリアしました", count))
end)

-------- 選択ボタン（SP） --------

bindSelectButton(
	spSet._02_.Frame.TextButton,
	sp_modelOV,
	spSet._02_.Frame.TextLabel,
	spSet._02_.Frame,
	spSet._02_.CancelButton,
	function(obj) return obj:IsA("Model") end,
	"Model",
	"[SP] 配置する Model を選択してください",
	function(obj)
		SP.placeModel = obj
		setLabelValue(spSet._02_.Frame.TextLabel, obj)
		log(LogColor.INFO, "[SP] 配置モデル: " .. obj.Name)
	end
)

bindSelectButton(
	spSet._03_.Frame.TextButton,
	sp_outputOV,
	spSet._03_.Frame.TextLabel,
	spSet._03_.Frame,
	spSet._03_.CancelButton,
	function(obj) return obj:IsA("Folder") end,
	"Folder",
	"[SP] 出力先 Folder を選択してください",
	function(obj)
		SP.outputFolder = obj
		setLabelValue(spSet._03_.Frame.TextLabel, obj)
		log(LogColor.INFO, "[SP] 出力先: " .. obj.Name)
	end
)

-------- 実行前バリデーション --------

local function validateSP()
	if #SP.pointsFolders == 0 then
		log(LogColor.ERROR, "[SP] 線形フォルダが1つも設定されていません"); return false
	end
	if not SP.placeModel then
		log(LogColor.ERROR, "[SP] 配置モデルが設定されていません"); return false
	end
	if spMode == "B" and #collectBTargetParts() == 0 then
		log(LogColor.ERROR, "[SP] パターンB: 対象CPが1つも設定されていません"); return false
	end
	return true
end

-------- 実行ボタン --------

structframe.Run.MouseButton1Click:Connect(function()
	log(LogColor.SUCCESS, "[SP] 実行しました")
	if not validateSP() then return end

	local cantOffsetLat  = parseNumber(spCfg._01_.Frame.TextBox.Text, SP_DEFAULT.cantOffsetLat, "横オフセット")
	local cantOffsetVert = parseNumber(spCfg._02_.Frame.TextBox.Text, SP_DEFAULT.cantOffsetVert, "縦オフセット")
	local alignToCant    = getSpCantTsuiju()
	local hanten         = getSpHanten()
	local snapToCp       = getSpSnapToCp()
	local hani           = parseHani(spCfg._05_.Frame.TextBox.Text)

	local intervalBase      = nil
	local intervalUnit      = nil
	local intervalMin       = nil
	local curvatureScale    = nil
	local studsPerMeter     = nil
	local targetNodes       = nil
	local targetNodesParts  = nil

	if spMode == "A" then
		local defaultInterval = SP_DEFAULT.intervalBase[spUnitMode]
		intervalBase   = parseNumber(spIntervalBox.Text, defaultInterval, "間隔")
		intervalUnit   = spUnitMode
		local minRaw   = spModeA._02_.Frame.TextBox.Text
		intervalMin    = (minRaw ~= "") and parseNumber(minRaw, nil) or nil
		curvatureScale = parseNumber(spModeA._03_.Frame.TextBox.Text, SP_DEFAULT.curvatureScale, "曲率縮小係数")
		studsPerMeter  = parseNumber(spModeA._04_.Frame.TextBox.Text, SP_DEFAULT.studsPerMeter, "スタッド/m")
	else
		targetNodes = collectBTargetNodes()
		targetNodesParts = collectBTargetParts()
	end

	local names = {}
	for _, f in ipairs(SP.pointsFolders) do table.insert(names, f.Name) end
	log(LogColor.INFO, string.format("[SP] 線形フォルダ (%d件): %s", #SP.pointsFolders, table.concat(names, ", ")))
	log(LogColor.INFO, "[SP] 配置モデル:       " .. tostring(SP.placeModel and SP.placeModel.Name))
	log(LogColor.INFO, "[SP] 出力先:           " .. tostring(SP.outputFolder and SP.outputFolder.Name))
	log(LogColor.INFO, "[SP] 横オフセット:     " .. cantOffsetLat)
	log(LogColor.INFO, "[SP] 縦オフセット:     " .. cantOffsetVert)
	log(LogColor.INFO, "[SP] カント追従:       " .. tostring(alignToCant))
	log(LogColor.INFO, "[SP] 反転:             " .. tostring(hanten))
	log(LogColor.INFO, "[SP] 範囲(HANI):       " .. (hani and (hani[1] .. "〜" .. hani[2]) or "全区間"))
	log(LogColor.INFO, "[SP] モード:           " .. spMode)
	log(LogColor.INFO, "[SP] CP揃え:           " .. tostring(snapToCp))
	if spMode == "A" then
		log(LogColor.INFO, "[SP] 間隔:             " .. tostring(intervalBase) .. " (" .. tostring(intervalUnit) .. ")")
		log(LogColor.INFO, "[SP] 最小間隔:         " .. tostring(intervalMin))
		log(LogColor.INFO, "[SP] 曲率縮小係数:     " .. tostring(curvatureScale))
	else
		log(LogColor.INFO, "[SP] 対象CP数:         " .. #targetNodes)
	end

	local ok, result = pcall(function()
		return structPlacer.STRUCTPLACER_GENERATE(
			SP.pointsFolders,
			SP.outputFolder,
			SP.placeModel,
			cantOffsetLat,
			cantOffsetVert,
			alignToCant,
			hanten,
			hani,
			spMode,
			snapToCp,
			intervalBase,
			intervalUnit,
			intervalMin,
			curvatureScale,
			studsPerMeter,
			targetNodes,
			targetNodesParts
		)
	end)

	if not ok then log(LogColor.ERROR, "[SP] エラー: " .. tostring(result)); return end
	if result then log(LogColor.SUCCESS, "[SP] 正常に完了しました")
	else log(LogColor.ERROR, "[SP] StructPlacer が false を返しました") end
end)]]></ProtectedString>
			<bool name="Disabled">false</bool>
			<Content name="LinkedSource"><null></null></Content>
			<token name="RunContext">0</token>
			<string name="ScriptGuid">{154fe28f-8493-4772-dad3-91460a3dd9f8}</string>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">toolbar</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
		<Item class="ModuleScript" referent="RBX695F1C75CD2748C388789D973CD274D4">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local module = {}

function module.Generate(
	modulewhere,
	START_ATTACHMENTs,
	outputfolder,
	STUDS_PER_METER,
	GAUGE,
	CANT,
	NODE_INTERVAL,
	TRACK_OFFSETS
)

	--------------------------------------------------
	-- 設定
	--------------------------------------------------

	local SAMPLE_INTERVAL = 0.005
	local BASE_ROLL = math.atan(CANT / GAUGE)

	local ELEMENT_COLORS = {
		line      = Color3.fromRGB(200, 200, 200),
		arc       = Color3.fromRGB( 80, 160, 255),
		clothoid  = Color3.fromRGB(  0, 220, 180),
		Narc      = Color3.fromRGB(255, 160,  50),
		Nclothoid = Color3.fromRGB(255, 220,  50),
	}

	--------------------------------------------------
	-- start attachment
	--------------------------------------------------

	local START_ATTACHMENT

	if START_ATTACHMENTs:IsA("Attachment") then
		START_ATTACHMENT = START_ATTACHMENTs
	else
		START_ATTACHMENT = START_ATTACHMENTs:FindFirstChildWhichIsA("Attachment")
	end

	if not START_ATTACHMENT then
		error("Start Attachment not found")
	end

	local BASE_CFRAME = START_ATTACHMENT.WorldCFrame

	--------------------------------------------------
	-- utilities
	--------------------------------------------------

	local function sign(x)
		if x > 0 then return 1 end
		if x < 0 then return -1 end
		return 0
	end

	local function curvatureFromRadius(r)
		if r == math.huge or r == -math.huge then return 0 end
		if r == 0 then return 0 end
		return 1 / r
	end

	local function lerp(a, b, t)
		return a + (b - a) * t
	end

	--------------------------------------------------
	-- 要素の正規化
	-- length を必ず正の値に、radius の符号で方向を表現する
	-- （手打ちで負の length が渡されても正しく処理できるようにする）
	--------------------------------------------------

	local function normalizeElement(e)
		-- length が負または 0 の場合は abs を取る
		-- radius の符号は保持する（曲率の方向を表すため）
		local n = {}
		for k, v in pairs(e) do n[k] = v end

		if n.length and n.length < 0 then
			n.length = math.abs(n.length)
		end

		-- clothoid / Nclothoid の startRadius / endRadius が
		-- math.huge の符号違いで渡された場合も吸収
		if n.startRadius and n.startRadius == -math.huge then
			n.startRadius = math.huge
		end
		if n.endRadius and n.endRadius == -math.huge then
			n.endRadius = math.huge
		end

		return n
	end

	--------------------------------------------------
	-- offset alignment
	--------------------------------------------------

	local function offsetSamples(samples, offset)
		local out = {}
		for _, n in ipairs(samples) do
			local forward = Vector3.new(
				math.cos(n.heading),
				0,
				math.sin(n.heading)
			)
			local right = Vector3.yAxis:Cross(forward).Unit
			table.insert(out, {
				x           = n.x + right.X * offset,
				z           = n.z + right.Z * offset,
				heading     = n.heading,
				roll        = n.roll,
				elementType = n.elementType,
			})
		end
		return out
	end

	local function recomputeS(samples)
		local out = {}
		local s = 0
		table.insert(out, {
			s           = 0,
			x           = samples[1].x,
			z           = samples[1].z,
			heading     = samples[1].heading,
			roll        = samples[1].roll,
			elementType = samples[1].elementType,
		})
		for i = 2, #samples do
			local dx = samples[i].x - samples[i-1].x
			local dz = samples[i].z - samples[i-1].z
			s += math.sqrt(dx*dx + dz*dz)
			table.insert(out, {
				s           = s,
				x           = samples[i].x,
				z           = samples[i].z,
				heading     = samples[i].heading,
				roll        = samples[i].roll,
				elementType = samples[i].elementType,
			})
		end
		return out
	end

	--------------------------------------------------
	-- STEP1 高密度線形生成
	--------------------------------------------------

	local function solveAlignment(elements)
		local samples = {}
		local x, z   = 0, 0
		local heading = 0
		local roll    = 0
		local sTotal  = 0

		table.insert(samples, {s=0, x=0, z=0, heading=0, roll=0, elementType="line"})

		local function addSample(eType)
			table.insert(samples, {
				s           = sTotal,
				x           = x,
				z           = z,
				heading     = heading,
				roll        = roll,
				elementType = eType,
			})
		end

		for _, raw in ipairs(elements) do
			local e = normalizeElement(raw)  -- ← 正規化

			if e.type == "line" then
				local s = 0
				while s < e.length do
					local ds = math.min(SAMPLE_INTERVAL, e.length - s)
					x += math.cos(heading) * ds
					z += math.sin(heading) * ds
					roll    = 0
					sTotal += ds
					s      += ds
					addSample("line")
				end

			elseif e.type == "arc" then
				local k = curvatureFromRadius(e.radius)
				local s = 0
				while s < e.length do
					local ds = math.min(SAMPLE_INTERVAL, e.length - s)
					heading += k * ds
					x += math.cos(heading) * ds
					z += math.sin(heading) * ds
					roll    = BASE_ROLL * sign(k)
					sTotal += ds
					s      += ds
					addSample("arc")
				end

			elseif e.type == "clothoid" then
				local k0 = curvatureFromRadius(e.startRadius)
				local k1 = curvatureFromRadius(e.endRadius)
				local rollStart = BASE_ROLL * sign(k0)
				local rollEnd   = BASE_ROLL * sign(k1)
				local s = 0
				while s < e.length do
					local t  = s / e.length
					local k  = lerp(k0, k1, t)
					local ds = math.min(SAMPLE_INTERVAL, e.length - s)
					heading += k * ds
					x += math.cos(heading) * ds
					z += math.sin(heading) * ds
					roll    = lerp(rollStart, rollEnd, t)
					sTotal += ds
					s      += ds
					addSample("clothoid")
				end

			elseif e.type == "Narc" then
				local k = curvatureFromRadius(e.radius)
				local s = 0
				while s < e.length do
					local ds = math.min(SAMPLE_INTERVAL, e.length - s)
					heading += k * ds
					x += math.cos(heading) * ds
					z += math.sin(heading) * ds
					roll    = 0
					sTotal += ds
					s      += ds
					addSample("Narc")
				end

			elseif e.type == "Nclothoid" then
				local k0 = curvatureFromRadius(e.startRadius)
				local k1 = curvatureFromRadius(e.endRadius)
				local s  = 0
				while s < e.length do
					local t  = s / e.length
					local k  = lerp(k0, k1, t)
					local ds = math.min(SAMPLE_INTERVAL, e.length - s)
					heading += k * ds
					x += math.cos(heading) * ds
					z += math.sin(heading) * ds
					roll    = 0
					sTotal += ds
					s      += ds
					addSample("Nclothoid")
				end
			end
		end

		return samples
	end

	--------------------------------------------------
	-- Control Tag 生成
	--------------------------------------------------

	local function buildControlTags(elements, offset)
		local tags  = {}
		local x, z  = 0, 0
		local heading = 0
		local index   = 0

		local function radiusText(r)
			if r == math.huge then return "inf" end
			return tostring(r or 0)
		end

		local function addTag(e)
			local r = radiusText(e.radius)
			local l = tostring(e.length or 0)
			table.insert(tags, {
				x       = x,
				z       = z,
				heading = heading,
				name    = string.format("CT_%03d_%s_%s_%s_%s", index, tostring(offset), e.type, r, l),
			})
			index += 1
		end

		for _, raw in ipairs(elements) do
			local e = normalizeElement(raw)  -- ← 正規化
			addTag(e)

			local s = 0
			while s < e.length do
				local ds = math.min(SAMPLE_INTERVAL, e.length - s)
				local k  = 0

				if e.type == "arc" or e.type == "Narc" then
					k = curvatureFromRadius(e.radius)
				elseif e.type == "clothoid" or e.type == "Nclothoid" then
					local k0 = curvatureFromRadius(e.startRadius)
					local k1 = curvatureFromRadius(e.endRadius)
					k = lerp(k0, k1, s / e.length)
				end

				heading += k * ds
				x += math.cos(heading) * ds
				z += math.sin(heading) * ds
				s += ds
			end
		end

		-- 最終端
		table.insert(tags, {
			x       = x,
			z       = z,
			heading = heading,
			name    = string.format("CT_%03d_%s_END", index, tostring(offset)),
		})

		return tags
	end

	--------------------------------------------------
	-- STEP2 ノード生成
	--------------------------------------------------

	local function buildNodes(samples, nodeInterval)
		local nodes = {}
		local nodeS = 0
		local i     = 1

		while nodeS <= samples[#samples].s do
			while samples[i+1] and samples[i+1].s < nodeS do
				i += 1
			end

			local a = samples[i]
			local b = samples[i+1]
			if not b then break end

			local t = (nodeS - a.s) / (b.s - a.s)
			table.insert(nodes, {
				x           = lerp(a.x, b.x, t),
				z           = lerp(a.z, b.z, t),
				heading     = lerp(a.heading, b.heading, t),
				roll        = lerp(a.roll, b.roll, t),
				elementType = a.elementType,
			})

			nodeS += nodeInterval
		end

		return nodes
	end

	--------------------------------------------------
	-- ノード配置
	--------------------------------------------------

	local function placeNode(node, index, offset, parent)
		local basePos = Vector3.new(
			node.x * STUDS_PER_METER,
			0,
			node.z * STUDS_PER_METER
		)
		local forward = Vector3.new(math.cos(node.heading), 0, math.sin(node.heading))
		local up      = Vector3.yAxis
		local right   = forward:Cross(up).Unit
		up            = right:Cross(forward).Unit

		local pos     = basePos + right * (offset * STUDS_PER_METER)
		local rollCF  = CFrame.fromAxisAngle(forward, node.roll)
		right         = rollCF:VectorToWorldSpace(right)
		up            = rollCF:VectorToWorldSpace(up)

		local cf = BASE_CFRAME * CFrame.fromMatrix(pos, right, up)

		local p           = Instance.new("Part")
		p.Anchored        = true
		p.Size            = Vector3.new(1, 1, 1)
		p.Name            = string.format("CP_%06d", index)
		p.CFrame          = cf
		p.Color           = ELEMENT_COLORS[node.elementType] or Color3.fromRGB(255, 255, 255)
		p.Parent          = parent
	end

	local function placeCT(tag, parent)
		local basePos = Vector3.new(
			tag.x * STUDS_PER_METER,
			0,
			tag.z * STUDS_PER_METER
		)
		local forward = Vector3.new(math.cos(tag.heading), 0, math.sin(tag.heading))
		local up      = Vector3.yAxis
		local right   = forward:Cross(up).Unit
		up            = right:Cross(forward).Unit

		local cf = BASE_CFRAME * CFrame.fromMatrix(basePos, right, up)

		local p        = Instance.new("Part")
		p.Anchored     = true
		p.Size         = Vector3.new(2, 2, 2)
		p.Name         = tag.name
		p.Color        = Color3.fromRGB(255, 50, 50)
		p.CFrame       = cf
		p.Parent       = parent
	end

	--------------------------------------------------
	-- Generate
	--------------------------------------------------

	local railData = require(modulewhere)
	local elements = railData.alignment.elements
	local root     = outputfolder or workspace

	local baseSamples = solveAlignment(elements)

	for _, offset in ipairs(TRACK_OFFSETS or {0}) do
		local samplesOffset = offsetSamples(baseSamples, offset)
		local samplesWithS  = recomputeS(samplesOffset)
		local nodes         = buildNodes(samplesWithS, NODE_INTERVAL)

		local folder     = Instance.new("Folder")
		folder.Name      = "Track_" .. offset
		folder.Parent    = root

		for i, node in ipairs(nodes) do
			placeNode(node, i, 0, folder)
		end

		local ctFolder = Instance.new("Folder")
		ctFolder.Name   = "ControlTags"
		ctFolder.Parent = folder

		local controlTags = buildControlTags(elements, offset)
		local ctOffset    = offsetSamples(controlTags, offset)
		for i, tag in ipairs(ctOffset) do
			tag.name = controlTags[i].name
			placeCT(tag, ctFolder)
		end
	end

	return true
end

return module]]></ProtectedString>
