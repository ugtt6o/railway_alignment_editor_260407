		<Item class="ModuleScript" referent="RBXDB4BF2313E6644F6B5E234941778C95E">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local module = {}

--[[
  STRUCTPLACER_GENERATE
  -----------------------------------------------------------------------
  引数:
    POINTS_FOLDERS   []Folder
    OUTPUT_FOLDER    Folder|nil
    PLACE_MODEL      Model
    CANT_OFFSET_LAT  number
    CANT_OFFSET_VERT number
    ALIGN_TO_CANT    bool
    STRUCTURE_HANTEN bool
    STRUCTURE_HANI   {min,max}|nil
    MODE             "A"|"B"
    SNAP_TO_CP       bool
    INTERVAL_BASE    number
    INTERVAL_UNIT    "cp"|"meter"
    INTERVAL_MIN     number|nil
    CURVATURE_SCALE  number
    STUDS_PER_METER  number
    TARGET_NODES     []number
--]]

function module.STRUCTPLACER_GENERATE(
	POINTS_FOLDERS,
	OUTPUT_FOLDER,
	PLACE_MODEL,
	CANT_OFFSET_LAT,
	CANT_OFFSET_VERT,
	ALIGN_TO_CANT,
	STRUCTURE_HANTEN,
	STRUCTURE_HANI,
	MODE,
	SNAP_TO_CP,
	INTERVAL_BASE,
	INTERVAL_UNIT,
	INTERVAL_MIN,
	CURVATURE_SCALE,
	STUDS_PER_METER,
	TARGET_NODES,
	TARGET_NODES_PARTS  -- []BasePart パターンB専用
)

	CANT_OFFSET_LAT  = CANT_OFFSET_LAT  or 0
	CANT_OFFSET_VERT = CANT_OFFSET_VERT or 0
	ALIGN_TO_CANT    = ALIGN_TO_CANT    or false
	STRUCTURE_HANTEN = STRUCTURE_HANTEN or false
	STUDS_PER_METER  = STUDS_PER_METER  or 3.571428
	INTERVAL_BASE    = INTERVAL_BASE    or 5
	INTERVAL_UNIT    = INTERVAL_UNIT    or "cp"
	CURVATURE_SCALE  = CURVATURE_SCALE  or 0
	MODE             = MODE             or "A"
	SNAP_TO_CP       = (SNAP_TO_CP == true)

	local HANTEN_CF = STRUCTURE_HANTEN and CFrame.Angles(0, math.pi, 0) or CFrame.identity
	local HANI_MIN  = STRUCTURE_HANI and STRUCTURE_HANI[1] or nil
	local HANI_MAX  = STRUCTURE_HANI and STRUCTURE_HANI[2] or nil
	local ROOT      = OUTPUT_FOLDER or workspace

	if not PLACE_MODEL then
		warn("[STRUCTPLACER] PLACE_MODEL が nil です"); return false
	end
	if PLACE_MODEL:IsDescendantOf(workspace) then
		warn("[STRUCTPLACER] PLACE_MODEL が workspace 内にあります。ServerStorage 推奨です。")
	end

	local folderList
	if typeof(POINTS_FOLDERS) == "Instance" and POINTS_FOLDERS:IsA("Folder") then
		folderList = { POINTS_FOLDERS }
	elseif type(POINTS_FOLDERS) == "table" then
		folderList = POINTS_FOLDERS
	else
		warn("[STRUCTPLACER] POINTS_FOLDERS が不正です"); return false
	end

	if #folderList == 0 then
		warn("[STRUCTPLACER] POINTS_FOLDERS が空です"); return false
	end

	local targetSet = {}
	if MODE == "B" then
		-- TARGET_NODES_PARTS が優先。なければ空として扱い警告
		if not TARGET_NODES_PARTS or #TARGET_NODES_PARTS == 0 then
			warn("[STRUCTPLACER] パターンB: TARGET_NODES_PARTS が空です"); return false
		end
	end

	-- -------------------------------------------------------
	-- 共通ユーティリティ
	-- -------------------------------------------------------

	local function buildPlaceCF(cf, rz)
		local mid     = cf.Position
		local forward = -cf.LookVector

		if ALIGN_TO_CANT then
			local up    = cf.UpVector
			local right = forward:Cross(up).Unit
			up          = right:Cross(forward).Unit
			local baseCF   = CFrame.lookAt(mid, mid + forward, up)
			local offsetCF = baseCF
				+ baseCF.RightVector * (rz * CANT_OFFSET_LAT)
				+ baseCF.UpVector    * (rz * CANT_OFFSET_VERT)
			return offsetCF * HANTEN_CF
		else
			local cfFlat   = CFrame.lookAt(mid, mid + forward, Vector3.yAxis)
			local offsetCF = cfFlat
				+ cfFlat.RightVector * (rz * CANT_OFFSET_LAT)
				+ cfFlat.UpVector    * (rz * CANT_OFFSET_VERT)
			return offsetCF * HANTEN_CF
		end
	end

	local function getCantAngle(cf)
		local _, _, rz = cf:ToOrientation()
		return rz
	end

	local function placeAt(cf, structFolder)
		local rz    = getCantAngle(cf)
		local clone = PLACE_MODEL:Clone()
		clone.Parent = structFolder
		clone:PivotTo(buildPlaceCF(cf, rz))
	end

	-- -------------------------------------------------------
	-- 曲率縮小（R=300m基準の正規化）
	-- R=300m・nodeInterval=2m の1CP角度差 ≈ 2/300 rad を基準(=1.0)とする
	-- base / (1 + normalizedCurv * SCALE) で間隔を縮小する
	-- -------------------------------------------------------
	local MAX_CURVATURE = 2 / 300  -- ≈ 0.00667 rad

	local function applyCurvatureScale(base, f0, f1)
		if CURVATURE_SCALE <= 0 then return base end
		local curvature      = math.acos(math.clamp(f0:Dot(f1), -1, 1))
		local normalizedCurv = math.min(curvature / MAX_CURVATURE, 1.0)
		return base / (1 + normalizedCurv * CURVATURE_SCALE)
	end

	-- -------------------------------------------------------
	-- SNAP_TO_CP = true 用
	-- -------------------------------------------------------

	local function calcIntervalCp(parts, i)
		local base = INTERVAL_BASE

		if i < #parts then
			local f0 = -parts[i].CFrame.LookVector
			local f1 = -parts[i + 1].CFrame.LookVector
			base = applyCurvatureScale(base, f0, f1)
		end

		if INTERVAL_MIN then
			base = math.max(INTERVAL_MIN, base)
		else
			base = math.max(0.001, base)
		end

		if INTERVAL_UNIT == "meter" then
			local cpDistStuds  = (i < #parts)
				and (parts[i + 1].Position - parts[i].Position).Magnitude
				or  STUDS_PER_METER
			local cpDistMeters = math.max(cpDistStuds / STUDS_PER_METER, 0.0001)
			base = base / cpDistMeters
		end

		return math.max(1, math.floor(base + 0.5))
	end

	-- -------------------------------------------------------
	-- SNAP_TO_CP = false 用
	-- -------------------------------------------------------

	local function buildCumDist(parts)
		local cumDist = { 0 }
		for j = 2, #parts do
			local d = (parts[j].Position - parts[j - 1].Position).Magnitude
			cumDist[j] = cumDist[j - 1] + d
		end
		return cumDist
	end

	local function interpAtDist(parts, cumDist, targetStuds)
		local lo, hi = 1, #parts
		while lo < hi - 1 do
			local mid = math.floor((lo + hi) / 2)
			if cumDist[mid] <= targetStuds then lo = mid else hi = mid end
		end

		local segLen = cumDist[hi] - cumDist[lo]
		local t = segLen > 0.0001 and (targetStuds - cumDist[lo]) / segLen or 0
		t = math.clamp(t, 0, 1)
		return parts[lo].CFrame:Lerp(parts[hi].CFrame, t), lo
	end

	local function calcIntervalStuds(parts, cumDist, cpIndex)
		local base = INTERVAL_BASE

		if cpIndex < #parts then
			local f0 = -parts[cpIndex].CFrame.LookVector
			local f1 = -parts[cpIndex + 1].CFrame.LookVector
			base = applyCurvatureScale(base, f0, f1)
		end

		if INTERVAL_MIN then
			base = math.max(INTERVAL_MIN, base)
		else
			base = math.max(0.001, base)
		end

		if INTERVAL_UNIT == "meter" then
			return base * STUDS_PER_METER
		else
			local cpCount   = math.max(1, math.floor(base + 0.5))
			local totalLen  = cumDist[#cumDist]
			local avgCpDist = totalLen / math.max(#parts - 1, 1)
			return cpCount * avgCpDist
		end
	end

	-- -------------------------------------------------------
	-- 1フォルダ分の処理
	-- -------------------------------------------------------
	local function processFolder(parts, structFolder)

		if MODE == "A" then

			if SNAP_TO_CP then
				local i = 1
				while i <= #parts do
					local cpNum  = tonumber(parts[i].Name:match("%d+")) or 0
					local inHani = true
					if HANI_MIN and cpNum < HANI_MIN then inHani = false end
					if HANI_MAX and cpNum > HANI_MAX then inHani = false end
					if inHani then placeAt(parts[i].CFrame, structFolder) end

					i += calcIntervalCp(parts, i)
				end

			else
				local cumDist    = buildCumDist(parts)
				local totalStuds = cumDist[#cumDist]
				local currentStuds = 0

				while currentStuds <= totalStuds do
					local cf, cpIndex = interpAtDist(parts, cumDist, currentStuds)
					local cpNum  = tonumber(parts[cpIndex].Name:match("%d+")) or 0
					local inHani = true
					if HANI_MIN and cpNum < HANI_MIN then inHani = false end
					if HANI_MAX and cpNum > HANI_MAX then inHani = false end
					if inHani then placeAt(cf, structFolder) end

					currentStuds += calcIntervalStuds(parts, cumDist, cpIndex)
				end
			end

		else
			for _, part in ipairs(parts) do
				local cpNum = tonumber(part.Name:match("%d+")) or 0
				if targetSet[cpNum] then
					local inHani = true
					if HANI_MIN and cpNum < HANI_MIN then inHani = false end
					if HANI_MAX and cpNum > HANI_MAX then inHani = false end
					if inHani then placeAt(part.CFrame, structFolder) end
				end
			end
		end
	end

	-- -------------------------------------------------------
	-- パターンB：TARGET_NODES の CFrame を直接使って配置
	-- POINTS_FOLDERS は参照しない
	-- -------------------------------------------------------
	if MODE == "B" then
		local structFolder = Instance.new("Folder")
		structFolder.Name  = "Structs_B"
		structFolder.Parent = ROOT

		-- TARGET_NODES は cp番号ではなく BasePart の参照を直接持つ想定
		-- sp_bTargetDir の ObjectValue.Value が BasePart なのでそのまま使う
		for _, part in ipairs(TARGET_NODES_PARTS or {}) do
			if part and part:IsA("BasePart") then
				placeAt(part.CFrame, structFolder)
			end
		end

		return true
	end

	-- -------------------------------------------------------
	-- パターンA：POINTS_FOLDERS をループ処理
	-- -------------------------------------------------------
	for _, pointsFolder in ipairs(folderList) do

		local parts = {}
		for _, child in ipairs(pointsFolder:GetChildren()) do
			if child:IsA("BasePart") then table.insert(parts, child) end
		end

		table.sort(parts, function(a, b)
			local na = tonumber(a.Name:match("%d+")) or 0
			local nb = tonumber(b.Name:match("%d+")) or 0
			return na < nb
		end)

		print(string.format("[STRUCTPLACER] '%s': CP数=%d  SNAP=%s", pointsFolder.Name, #parts, tostring(SNAP_TO_CP)))

		if #parts == 0 then
			warn(string.format("[STRUCTPLACER] '%s': CP が見つかりません。スキップします", pointsFolder.Name))
		else
			local trackRoot    = Instance.new("Folder")
			trackRoot.Name     = pointsFolder.Name
			trackRoot.Parent   = ROOT

			local structFolder  = Instance.new("Folder")
			structFolder.Name   = "Structs"
			structFolder.Parent = trackRoot

			processFolder(parts, structFolder)
		end
	end

	return true
end

return module]]></ProtectedString>
				<string name="ScriptGuid">{b946912d-df8c-6d1e-cd2a-51d035f258cf}</string>
				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">StructPlacer</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
	</Item>
</roblox>